# Normalize text files to LF in the repo
* text=auto eol=lf

# Binary assets should not be normalized
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.avif binary
*.ico  binary
*.bmp  binary
*.svg  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.mp4  binary
*.mov  binary
*.mp3  binary
*.wav  binary
